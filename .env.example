APP_MODE=demo

PROVIDER_CACHE_ENABLED=true
PROVIDER_CACHE_DIR=./fixtures/cache

ODDS_API_KEY=
ODDS_PROVIDER=auto
# auto | the-odds-api | bzzoiro
ODDS_SPORT_KEY=soccer_fifa_world_cup
ODDS_REGIONS=eu
ODDS_MARKETS=h2h
ODDS_COMMENCE_TIME_FROM=2026-06-11T00:00:00Z
ODDS_COMMENCE_TIME_TO=2026-07-19T23:59:59Z
ODDS_CACHE_TTL_SECONDS=1800

POLYMARKET_PUBLIC_ENABLED=true
# 本地 VPN 调试：填 host:port 或完整 URL，亦可用 HTTPS_PROXY / HTTP_PROXY
POLYMARKET_HTTPS_PROXY=127.0.0.1:3213
POLYMARKET_VPS_SSH_HOST=nice-ai-LZ
POLYMARKET_TAG_ID=
POLYMARKET_SLUG=
# 世界杯单场 h2h（fifwc）series；默认 11433
POLYMARKET_FIFWC_SERIES_ID=11433
POLYMARKET_SEARCH_TERMS=world cup,世界杯
POLYMARKET_LIMIT=200
POLYMARKET_CACHE_TTL_SECONDS=900

SPORTMONKS_API_TOKEN=
SPORTMONKS_START_DATE=2026-06-11
SPORTMONKS_END_DATE=2026-07-19

FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_COMPETITION_CODE=WC
FOOTBALL_DATA_DATE_FROM=2026-06-11
FOOTBALL_DATA_DATE_TO=2026-07-19
FOOTBALL_DATA_CACHE_TTL_SECONDS=300

JINGCAI_OFFICIAL_FEED_MODE=auto
# auto = replay 读 file 快照，real 走 webapi.sporttery.cn live（推荐）
# webapi = 强制实时拉体彩网关
# file = 读本地快照（离线 replay / CI）
# JINGCAI_OFFICIAL_FEED_MODE=webapi
JINGCAI_OFFICIAL_FEED_FILE=./fixtures/snapshots/latest/jingcai-official-feed.json
JINGCAI_WEBAPI_CACHE_TTL_SECONDS=300
# webapi 失败时回退 file 快照（research/demo 默认 true）
JINGCAI_WEBAPI_SNAPSHOT_FALLBACK_ENABLED=true
JINGCAI_OFFICIAL_FEED_URL=
SPORTTERY_CLIENT_CODE=3001
JINGCAI_WEBAPI_LEAGUE_FILTER=世界杯
JINGCAI_WEBAPI_ALIGN_BASELINE_TEAMS=true
ENABLE_STAKE_SUGGESTION=false
RECOMMENDATION_RISK_PROFILE=strict

BZZOIRO_API_TOKEN=
BZZOIRO_DATE_FROM=2026-06-11
BZZOIRO_DATE_TO=2026-07-19
BZZOIRO_LEAGUE=27
BZZOIRO_TIMEZONE=UTC
BZZOIRO_ODDS_EVENT_LIMIT=104
# 并行拉取每场 /odds/ 的 batch 大小（104 场约 21 批）
BZZOIRO_ODDS_FETCH_BATCH_SIZE=5
BZZOIRO_CACHE_TTL_SECONDS=1800

# Gemini（竞彩 semi-auto 草稿；真实 key 只放 .env）
GEMINI_API_KEY=
GEMINI_HTTPS_PROXY=127.0.0.1:3213
GEMINI_MODEL=gemini-3.5-flash
# official=仅 sporttery.cn（URL context + site: 搜索 + 代码过滤）；open_search=允许第三方转载
JINGCAI_GEMINI_SOURCE_MODE=official
JINGCAI_GEMINI_OFFICIAL_DOMAINS=sporttery.cn,www.sporttery.cn
JINGCAI_GEMINI_OFFICIAL_URLS=https://www.sporttery.cn/jc/zqszsc/,https://www.sporttery.cn/

MARKET_DATA_MODE=real
LIVE_DATA_MODE=real
LIVE_SNAPSHOT_REPLAY_ENABLED=
LIVE_SNAPSHOT_REPLAY_FILE=./fixtures/snapshots/latest/live-data.json
